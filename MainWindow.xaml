<Window x:Class="TempNoteManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Temp Note Manager для Notepad++"
        Width="1360"
        Height="820"
        MinWidth="1120"
        MinHeight="680"
        Loaded="Window_Loaded">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#BFC7D1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#26313F" />
        </Style>

        <Style x:Key="TinyButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Width" Value="34" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="#C9D0D8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="MetaLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#657386" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>

        <Style x:Key="MetaValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2A36" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="RowItemStyle" TargetType="DataGridRow">
            <Setter Property="ToolTipService.InitialShowDelay" Value="350" />
            <EventSetter Event="MouseEnter" Handler="ItemContainer_MouseEnter" />
            <Setter Property="ToolTip">
                <Setter.Value>
                    <ToolTip DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                             MaxWidth="520">
                        <StackPanel Width="500">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       Foreground="#1F2A36"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding StorageText}"
                                       Foreground="#2B7A78"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="{Binding CategoryText}"
                                       Foreground="#59677A"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="{Binding TagsText}"
                                       Foreground="#7C3AED"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="{Binding Summary}"
                                       Foreground="#354252"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0" />
                            <TextBlock Text="{Binding SummaryState}"
                                       Foreground="#8A5B00"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0" />
                            <Separator Margin="0,8" />
                            <TextBlock Text="{Binding PreviewText}"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Foreground="#28313D"
                                       TextWrapping="Wrap"
                                       MaxHeight="260" />
                        </StackPanel>
                    </ToolTip>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardItemStyle" TargetType="ListBoxItem">
            <Setter Property="Width" Value="302" />
            <Setter Property="Height" Value="164" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="350" />
            <EventSetter Event="MouseEnter" Handler="ItemContainer_MouseEnter" />
            <Setter Property="ToolTip">
                <Setter.Value>
                    <ToolTip DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                             MaxWidth="520">
                        <StackPanel Width="500">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       Foreground="#1F2A36"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding StorageText}"
                                       Foreground="#2B7A78"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="{Binding CategoryText}"
                                       Foreground="#59677A"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="{Binding TagsText}"
                                       Foreground="#7C3AED"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="{Binding Summary}"
                                       Foreground="#354252"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0" />
                            <TextBlock Text="{Binding SummaryState}"
                                       Foreground="#8A5B00"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0" />
                            <Separator Margin="0,8" />
                            <TextBlock Text="{Binding PreviewText}"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Foreground="#28313D"
                                       TextWrapping="Wrap"
                                       MaxHeight="260" />
                        </StackPanel>
                    </ToolTip>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CategoryFileItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="350" />
            <EventSetter Event="MouseEnter" Handler="ItemContainer_MouseEnter" />
            <Setter Property="ToolTip">
                <Setter.Value>
                    <ToolTip DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                             MaxWidth="520">
                        <StackPanel Width="500">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       Foreground="#1F2A36"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding PathText}"
                                       Foreground="#59677A"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="{Binding TagsText}"
                                       Foreground="#7C3AED"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="{Binding Summary}"
                                       Foreground="#354252"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0" />
                            <Separator Margin="0,8" />
                            <TextBlock Text="{Binding PreviewText}"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Foreground="#28313D"
                                       TextWrapping="Wrap"
                                       MaxHeight="260" />
                        </StackPanel>
                    </ToolTip>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Background="#F3F5F7">
        <Border DockPanel.Dock="Top"
                Background="#FFFFFF"
                BorderBrush="#D9DEE5"
                BorderThickness="0,0,0,1"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="True">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Обновить"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Click="Refresh_Click" />
                        <Button Content="Удалить"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Click="DeleteSelected_Click" />
                        <Button Content="Переим."
                                Style="{StaticResource ToolbarButtonStyle}"
                                Click="RenameSelected_Click" />
                        <Button Content="↑"
                                Style="{StaticResource TinyButtonStyle}"
                                ToolTip="Поднять выбранный файл"
                                Click="MoveSelectedUp_Click" />
                        <Button Content="↓"
                                Style="{StaticResource TinyButtonStyle}"
                                ToolTip="Опустить выбранный файл"
                                Click="MoveSelectedDown_Click" />
                        <Button Content="Экспорт temp"
                                Style="{StaticResource ToolbarButtonStyle}"
                                MinWidth="112"
                                Click="ExportTemporary_Click" />
                        <Button Content="AI тэги"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Click="AnalyzeVisibleWithAi_Click" />
                        <Button Content="AI категории"
                                Style="{StaticResource ToolbarButtonStyle}"
                                MinWidth="112"
                                Click="SuggestCategoriesWithAi_Click" />
                        <Button Content="Порядок"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Click="SaveOrder_Click" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Temp Note Manager"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#1E2A36"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="StatusTextBlock"
                                   Margin="18,0,0,0"
                                   Foreground="#697789"
                                   VerticalAlignment="Center"
                                   Text="Готово" />
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="78" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="1.35*" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="210" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="session"
                               VerticalAlignment="Center"
                               Foreground="#59677A" />
                    <TextBox x:Name="SessionPathBox"
                             Grid.Column="1"
                             Style="{StaticResource InputStyle}" />
                    <Button Grid.Column="2"
                            Content="..."
                            Style="{StaticResource TinyButtonStyle}"
                            ToolTip="Выбрать session.xml"
                            Click="BrowseSession_Click" />

                    <CheckBox x:Name="AiEnabledBox"
                              Grid.Column="4"
                              Content="AI"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0" />
                    <TextBox x:Name="AiEndpointBox"
                             Grid.Column="5"
                             Style="{StaticResource InputStyle}"
                             Margin="0,0,8,0" />
                    <TextBox x:Name="AiModelBox"
                             Grid.Column="6"
                             Style="{StaticResource InputStyle}"
                             Margin="0,0,8,0" />
                    <PasswordBox x:Name="AiKeyBox"
                                 Grid.Column="7"
                                 Height="32"
                                 Padding="8,4"
                                 BorderBrush="#C9D0D8"
                                 BorderThickness="1"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,8,0" />
                    <Button Grid.Column="8"
                            Content="Сохранить"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Click="SaveSettings_Click" />
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="78" />
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="112" />
                        <ColumnDefinition Width="1.4*" />
                        <ColumnDefinition Width="34" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="корзина"
                               VerticalAlignment="Center"
                               Foreground="#59677A" />
                    <ComboBox x:Name="TrashModeBox"
                              Grid.Column="1"
                              Height="32"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Windows" Tag="RecycleBin" />
                        <ComboBoxItem Content="Папка" Tag="CustomFolder" />
                    </ComboBox>
                    <TextBox x:Name="TrashFolderBox"
                             Grid.Column="2"
                             Style="{StaticResource InputStyle}"
                             Margin="8,0,0,0" />
                    <Button Grid.Column="3"
                            Content="..."
                            Style="{StaticResource TinyButtonStyle}"
                            ToolTip="Выбрать папку корзины"
                            Click="BrowseTrash_Click" />

                    <TextBlock Grid.Column="5"
                               Text="категории"
                               VerticalAlignment="Center"
                               Foreground="#59677A" />
                    <TextBox x:Name="CategoryRootBox"
                             Grid.Column="6"
                             Style="{StaticResource InputStyle}" />
                    <Button Grid.Column="7"
                            Content="..."
                            Style="{StaticResource TinyButtonStyle}"
                            ToolTip="Выбрать корневую папку категорий"
                            Click="BrowseCategoryRoot_Click" />
                </Grid>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="SplitterColumn" Width="0" />
                <ColumnDefinition x:Name="DetailColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="330" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="SearchBox"
                             Grid.Column="0"
                             Style="{StaticResource InputStyle}"
                             TextChanged="SearchBox_TextChanged" />
                    <RadioButton x:Name="TableViewButton"
                                 Grid.Column="2"
                                 Content="Таблица"
                                 IsChecked="True"
                                 GroupName="ViewMode"
                                 VerticalAlignment="Center"
                                 Checked="ViewMode_Checked" />
                    <RadioButton x:Name="CardsViewButton"
                                 Grid.Column="3"
                                 Content="Карточки"
                                 GroupName="ViewMode"
                                 VerticalAlignment="Center"
                                 Margin="14,0,0,0"
                                 Checked="ViewMode_Checked" />
                    <CheckBox x:Name="TempOnlyBox"
                              Grid.Column="5"
                              Content="Только временные"
                              VerticalAlignment="Center"
                              Checked="Filter_Changed"
                              Unchecked="Filter_Changed" />
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="FilesGrid"
                              Grid.Column="0"
                              ItemsSource="{Binding ItemsView}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              RowHeight="36"
                              AlternatingRowBackground="#F9FAFB"
                              Background="#FFFFFF"
                              BorderBrush="#D8DEE6"
                              BorderThickness="1"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              RowStyle="{StaticResource RowItemStyle}"
                              AllowDrop="True"
                              PreviewMouseLeftButtonDown="DragSource_PreviewMouseLeftButtonDown"
                              MouseMove="DragSource_MouseMove"
                              DragOver="Items_DragOver"
                              Drop="Items_Drop"
                              SelectionChanged="Items_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Имя"
                                                Binding="{Binding DisplayName}"
                                                Width="240" />
                            <DataGridTextColumn Header="Тип"
                                                Binding="{Binding StorageText}"
                                                Width="150" />
                            <DataGridTextColumn Header="Создан"
                                                Binding="{Binding CreatedText}"
                                                Width="150" />
                            <DataGridTextColumn Header="Изменен"
                                                Binding="{Binding ModifiedText}"
                                                Width="150" />
                            <DataGridTextColumn Header="Размер"
                                                Binding="{Binding SizeText}"
                                                Width="90" />
                            <DataGridTextColumn Header="Категория"
                                                Binding="{Binding CategoryText}"
                                                Width="140" />
                            <DataGridTemplateColumn Header="AI тэги"
                                                    Width="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ItemsControl ItemsSource="{Binding Tags}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding Color}"
                                                            Padding="6,2"
                                                            Margin="0,0,4,0">
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="#FFFFFF"
                                                                   FontSize="11"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Путь"
                                                Binding="{Binding PathText}"
                                                Width="780" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <ListBox x:Name="CardsList"
                             Grid.Column="0"
                             ItemsSource="{Binding ItemsView}"
                             ItemContainerStyle="{StaticResource CardItemStyle}"
                             Background="Transparent"
                             BorderThickness="0"
                             Visibility="Collapsed"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionMode="Single"
                             AllowDrop="True"
                             PreviewMouseLeftButtonDown="DragSource_PreviewMouseLeftButtonDown"
                             MouseMove="DragSource_MouseMove"
                             DragOver="Items_DragOver"
                             Drop="Items_Drop"
                             SelectionChanged="Items_SelectionChanged">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel IsItemsHost="True" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FFFFFF"
                                        BorderBrush="#D8DEE6"
                                        BorderThickness="1"
                                        Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right"
                                                    Content="Переим."
                                                    Height="24"
                                                    MinWidth="64"
                                                    Margin="8,0,0,0"
                                                    Padding="6,0"
                                                    Click="RenameFile_Click" />
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="#1F2A36"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                        <StackPanel Grid.Row="1"
                                                    Orientation="Horizontal"
                                                    Margin="0,8,0,0">
                                            <TextBlock Text="{Binding StorageText}"
                                                       Foreground="#2B7A78"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding SizeText}"
                                                       Foreground="#697789"
                                                       Margin="12,0,0,0" />
                                            <TextBlock Text="{Binding CategoryText}"
                                                       Foreground="#697789"
                                                       Margin="12,0,0,0" />
                                        </StackPanel>
                                        <ItemsControl Grid.Row="2"
                                                      ItemsSource="{Binding Tags}"
                                                      Margin="0,8,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding Color}"
                                                            Padding="6,2"
                                                            Margin="0,0,4,4">
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="#FFFFFF"
                                                                   FontSize="11" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Grid.Row="2"
                                                   Text="{Binding PreviewText}"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   Foreground="#3B4654"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,34,0,0" />
                                        <TextBlock Grid.Row="3"
                                                   Text="{Binding ModifiedText}"
                                                   Foreground="#697789"
                                                   FontSize="12"
                                                   Margin="0,8,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Column="1"
                            Margin="12,0,0,0"
                            Background="#FFFFFF"
                            BorderBrush="#D8DEE6"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0"
                                       Margin="12"
                                       LastChildFill="True">
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal">
                                    <Button Content="+"
                                            Style="{StaticResource TinyButtonStyle}"
                                            ToolTip="Создать категорию"
                                            Click="CreateCategory_Click" />
                                </StackPanel>
                                <TextBlock Text="Категории"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#1F2A36"
                                           VerticalAlignment="Center" />
                            </DockPanel>

                            <ScrollViewer Grid.Row="1"
                                          Padding="12,0,12,12"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Categories}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F9FAFB"
                                                    BorderBrush="#D8DEE6"
                                                    BorderThickness="1"
                                                    Padding="10"
                                                    Margin="0,0,0,10"
                                                    AllowDrop="True"
                                                    DragOver="Category_DragOver"
                                                    Drop="Category_Drop">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <DockPanel Grid.Row="0"
                                                               LastChildFill="True">
                                                        <Button DockPanel.Dock="Right"
                                                                Content="Изм."
                                                                Height="24"
                                                                MinWidth="48"
                                                                Margin="8,0,0,0"
                                                                Padding="8,0"
                                                                Click="EditCategory_Click" />
                                                        <Border DockPanel.Dock="Left"
                                                                Width="10"
                                                                Height="24"
                                                                Background="{Binding Color}"
                                                                Margin="0,0,8,0" />
                                                        <TextBlock Text="{Binding DisplayTitle}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#1F2A36"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </DockPanel>
                                                    <TextBlock Grid.Row="1"
                                                               Text="{Binding Description}"
                                                               Foreground="#59677A"
                                                               TextWrapping="Wrap"
                                                               Margin="0,6,0,8" />
                                                    <TextBlock Grid.Row="2"
                                                               Text="{Binding DirectoryPath}"
                                                               Foreground="#7C8796"
                                                               FontSize="11"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,0,0,8" />
                                                    <ListBox Grid.Row="3"
                                                             ItemsSource="{Binding Items}"
                                                             ItemContainerStyle="{StaticResource CategoryFileItemStyle}"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             MaxHeight="170"
                                                             PreviewMouseLeftButtonDown="DragSource_PreviewMouseLeftButtonDown"
                                                             MouseMove="DragSource_MouseMove"
                                                             SelectionChanged="CategoryItems_SelectionChanged">
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="#FFFFFF"
                                                                        BorderBrush="#E0E5EC"
                                                                        BorderThickness="1"
                                                                        Padding="6"
                                                                        Margin="0,0,0,4">
                                                                    <DockPanel LastChildFill="True">
                                                                        <Button DockPanel.Dock="Right"
                                                                                Content="Переим."
                                                                                Height="24"
                                                                                MinWidth="64"
                                                                                Margin="8,0,0,0"
                                                                                Padding="6,0"
                                                                                Click="RenameFile_Click" />
                                                                        <TextBlock Text="{Binding DisplayName}"
                                                                                   Foreground="#26313F"
                                                                                   VerticalAlignment="Center"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                    </DockPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <GridSplitter x:Name="DetailSplitter"
                          Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          Background="#CBD3DD"
                          Visibility="Collapsed" />

            <Border x:Name="DetailPane"
                    Grid.Column="2"
                    Background="#FFFFFF"
                    BorderBrush="#D9DEE5"
                    BorderThickness="1,0,0,0"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               LastChildFill="True"
                               Margin="14,12,14,10">
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal">
                            <Button x:Name="SavePermanentButton"
                                    Content="Сохранить как..."
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Click="SaveTemporaryAsPermanent_Click" />
                            <Button x:Name="MakeTemporaryButton"
                                    Content="Сделать временным"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    MinWidth="142"
                                    Click="ConvertToTemporary_Click" />
                            <Button Content="AI summary"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Click="Summarize_Click" />
                            <Button Content="Переим."
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Click="RenameSelected_Click" />
                            <Button Content="Удалить"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Click="DeleteSelected_Click" />
                            <Button Content="×"
                                    Style="{StaticResource TinyButtonStyle}"
                                    FontSize="16"
                                    ToolTip="Закрыть"
                                    Click="CloseDetail_Click" />
                        </StackPanel>

                        <TextBlock Text="{Binding DisplayName}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2A36"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <Grid Grid.Row="1" Margin="14,0,14,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Путь" Style="{StaticResource MetaLabelStyle}" />
                            <TextBlock Text="{Binding PathText}" Style="{StaticResource MetaValueStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="Создан" Style="{StaticResource MetaLabelStyle}" />
                            <TextBlock Text="{Binding CreatedText}" Style="{StaticResource MetaValueStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="16,0,0,0">
                            <TextBlock Text="Изменен" Style="{StaticResource MetaLabelStyle}" />
                            <TextBlock Text="{Binding ModifiedText}" Style="{StaticResource MetaValueStyle}" />
                        </StackPanel>

                        <Border Grid.Row="2"
                                Grid.ColumnSpan="3"
                                Background="#F6F8FA"
                                BorderBrush="#E0E5EC"
                                BorderThickness="1"
                                Padding="10"
                                MinHeight="74">
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding Tags}"
                                              Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding Color}"
                                                    Padding="7,3"
                                                    Margin="0,0,5,5">
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="#FFFFFF"
                                                           FontSize="11" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding SummaryState}"
                                           Foreground="#8A5B00"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Summary}"
                                           Foreground="#26313F"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBox Grid.Row="2"
                             Text="{Binding FullContent}"
                             FontFamily="Consolas"
                             FontSize="13"
                             Foreground="#1E2630"
                             Background="#FFFFFF"
                             BorderThickness="0"
                             Padding="14"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
